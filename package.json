{
	"name": "aeare",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"convex:dev": "bunx convex dev",
		"build": "vite build",
		"deploy:convex": "bun ./scripts/deploy-blocked.mjs convex",
		"deploy:worker": "bun ./scripts/deploy-blocked.mjs worker",
		"deploy:worker:staging": "bun ./scripts/deploy-blocked.mjs preview",
		"deploy:staging": "bun ./scripts/deploy-blocked.mjs preview",
		"deploy:prod": "bun ./scripts/deploy-blocked.mjs production",
		"parity:build": "bun run build",
		"parity:serve": "bunx wrangler dev --local .svelte-kit/cloudflare/_worker.js --ip 127.0.0.1 --port 4173",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:convex": "vitest run --project convex",
		"test:convex:watch": "vitest --project convex",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:parity": "E2E_RUNTIME=parity playwright test --grep parity",
		"verify:deploy": "bun run check && bun run build && bun run test:e2e:parity"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260405.0",
		"@edge-runtime/vm": "^5.0.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.0.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"convex-test": "^0.0.47",
		"playwright": "^1.58.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.1.3",
		"workbox-window": "^7.4.0",
		"wrangler": "^4.80.0"
	},
	"dependencies": {
		"@auth/core": "0.37.0",
		"@convex-dev/auth": "^0.0.91",
		"convex": "^1.34.0",
		"convex-svelte": "^0.0.12",
		"dexie": "^4.3.0",
		"quagga": "^0.12.1",
		"zod": "^3.24.4"
	}
}
