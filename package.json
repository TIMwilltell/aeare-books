    "svelte-check": "^4.4.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0",
    "wrangler": "^4.63.0"
  },
  "dependencies": {
    "@playwright/test": "^1.58.2",
    "convex": "^1.34.0",
