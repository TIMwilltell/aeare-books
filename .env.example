# Safe template only. Never commit production URLs, deploy keys, or local secrets here.
# These values are for local development and local parity only.
# Cloudflare preview and production values live in the Cloudflare dashboard/build hook config.
PUBLIC_CONVEX_URL=

# Optional build-time fallback for local Vite-only workflows.
VITE_CONVEX_URL=

# Must point at the matching non-production Convex site URL for local auth/parity work.
PUBLIC_CONVEX_SITE_URL=

# Only needed for local dev inbox inspection routes.
CONVEX_DEPLOY_KEY=
