{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "aeare-books",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"compatibility_date": "2026-04-07",
	"compatibility_flags": ["nodejs_als", "nodejs_compat"],
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"browser": {
		"binding": "BROWSER"
	},
	"observability": {
		"enabled": true
	}
}
